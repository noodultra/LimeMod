{
	"schemaVersion": 1,
	"id": "limemod",
	"version": "${version}",
	"name": "limemod",
	"description": "这个模组添加了和青柠相关的物品",
	"authors": [
		"面缶"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/limemod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"top.limex.limemod.Limemod"
		],
		"client": [
			"top.limex.limemod.LimemodClient"
		],
		"fabric-datagen": [
			"top.limex.limemod.LimemodDataGenerator"
		]
	},
	"mixins": [
		"limemod.mixins.json",
		{
			"config": "limemod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.20.1",
		"java": ">=17",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}